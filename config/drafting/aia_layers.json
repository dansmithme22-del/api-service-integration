{
  "$comment": "AIA CAD Layer Guidelines (2nd ed.) + NCS v6 canonical layer set. See agent_docs/130_DRAFTING_STANDARDS.md for derivation and field meanings. Color is ACI (AutoCAD Color Index).",

  "format": "D-MMMM[-NNNN][-XXXX][-STAT]",

  "disciplines": {
    "G": "General",
    "H": "Hazardous Materials",
    "V": "Survey / Mapping",
    "B": "Geotechnical",
    "C": "Civil",
    "L": "Landscape",
    "S": "Structural",
    "A": "Architectural",
    "I": "Interiors",
    "Q": "Equipment",
    "F": "Fire Protection",
    "P": "Plumbing",
    "D": "Process",
    "M": "Mechanical",
    "E": "Electrical",
    "W": "Distributed Energy",
    "T": "Telecom",
    "R": "Resource",
    "X": "Other",
    "Z": "Contractor / Shop"
  },

  "status_codes": {
    "EXST": "Existing to remain",
    "DEMO": "To be demolished",
    "NEWW": "New work",
    "RELO": "To be relocated",
    "TEMP": "Temporary",
    "FUTR": "Future work",
    "PHS1": "Phase 1",
    "PHS2": "Phase 2",
    "PHS3": "Phase 3"
  },

