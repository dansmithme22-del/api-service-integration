# Copy to .env and fill in. .env is gitignored.

# Vision provider — leave blank to auto-detect from whichever key is set below.
# Valid: gemini | anthropic | openai
VISION_PROVIDER=

# Provider keys (set whichever you use; others can stay blank)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Archicad JSON API
ARCHICAD_PORT=19723

# Optional: project defaults
PROJECT_DEFAULT_UNITS=imperial      # imperial | metric
